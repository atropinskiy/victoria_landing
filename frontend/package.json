{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack --port 3001",
    "build": "next build",
    "start": "next start --hostname 0.0.0.0 --port 3001",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "lint:fsd": "steiger ./src",
    "gen:api": "openapi-typescript http://localhost:8001/openapi.json -o src/shared/api/schema.ts",
    "check": "npm run lint && npm run lint:fsd && npm run typecheck && npm run build",
    "clean": "rm -rf .next tsconfig.tsbuildinfo",
    "clean:full": "rm -rf .next node_modules tsconfig.tsbuildinfo package-lock.json && npm install"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@hookform/resolvers": "^5.4.0",
    "@tanstack/react-query": "^5.101.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "embla-carousel-react": "^8.6.0",
    "lucide-react": "^1.22.0",
    "next": "16.2.10",
    "next-intl": "^4.13.0",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.81.0",
    "shadcn": "^4.12.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "overrides": {
    "steiger": {
      "@feature-sliced/steiger-plugin": "0.5.8"
    }
  },
  "devDependencies": {
    "@feature-sliced/steiger-plugin": "^0.5.8",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@svgr/webpack": "^8.1.0",
    "@tailwindcss/postcss": "^4",
    "@tanstack/eslint-plugin-query": "^5.101.2",
    "@tanstack/react-query-devtools": "^5.101.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "eslint-config-prettier": "^10.1.8",
    "lint-staged": "^16.4.0",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.9.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "steiger": "^0.5.13",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
